    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mahoraga/core": "workspace:*",
    "@mahoraga/mapper": "workspace:*",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
