{
  "name": "@mahoraga/agent",
  "version": "0.1.0",
  "description": "AI agent dispatcher with adaptation loop for Mahoraga",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
