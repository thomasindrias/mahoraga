{
  "name": "mahoraga-agent",
  "version": "0.1.1",
  "description": "AI agent dispatcher with adaptation loop for Mahoraga",
  "license": "MIT",
  "author": "Thomas Indrias <thomasindrias@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasindrias/mahoraga.git",
    "directory": "packages/agent"
  },
  "homepage": "https://github.com/thomasindrias/mahoraga/tree/main/packages/agent",
  "bugs": {
    "url": "https://github.com/thomasindrias/mahoraga/issues"
  },
  "keywords": [
    "mahoraga",
    "ai-agent",
    "automated-fix",
    "pull-request"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:integration": "MAHORAGA_INTEGRATION_TESTS=true vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "check-exports": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "mahoraga-core": "workspace:*",
    "mahoraga-mapper": "workspace:*",
    "minimatch": "^10.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
