{
  "name": "@mahoraga/sources",
  "version": "0.1.0",
  "description": "Pluggable source adapters for Mahoraga",
  "license": "MIT",
  "author": "Thomas Indrias <thomasindrias@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasindrias/mahoraga.git",
    "directory": "packages/sources"
  },
  "homepage": "https://github.com/thomasindrias/mahoraga/tree/main/packages/sources",
  "bugs": {
    "url": "https://github.com/thomasindrias/mahoraga/issues"
  },
  "keywords": [
    "mahoraga",
    "analytics",
    "amplitude",
    "adapter"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@mahoraga/core": "workspace:*"
  },
  "devDependencies": {
    "msw": "^2.4.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "tsup": "^8.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
