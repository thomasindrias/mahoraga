{
  "name": "mahoraga-mapper",
  "version": "0.1.3",
  "description": "AST-based code-to-event mapping for Mahoraga",
  "license": "MIT",
  "author": "Thomas Indrias <thomasindrias@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasindrias/mahoraga.git",
    "directory": "packages/mapper"
  },
  "homepage": "https://github.com/thomasindrias/mahoraga/tree/main/packages/mapper",
  "bugs": {
    "url": "https://github.com/thomasindrias/mahoraga/issues"
  },
  "keywords": [
    "mahoraga",
    "ast",
    "css-selector",
    "source-map",
    "tsx"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "check-exports": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "glob": "^13.0.6",
    "mahoraga-core": "workspace:*",
    "typescript": "^5.5.0"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "vitest": "^4.1.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
