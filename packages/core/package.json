{
  "name": "mahoraga-core",
  "version": "0.1.1",
  "description": "Shared schemas, storage, types, and utilities for Mahoraga",
  "license": "MIT",
  "author": "Thomas Indrias <thomasindrias@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/thomasindrias/mahoraga.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/thomasindrias/mahoraga/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/thomasindrias/mahoraga/issues"
  },
  "keywords": [
    "mahoraga",
    "analytics",
    "schema",
    "zod",
    "sqlite"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "import": "./dist/testing/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "check-exports": "attw --pack . --profile esm-only"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "tsup": "^8.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  }
}
